{
  "hosting": [
    {
      "site": "nosh-order",
      "public": "customer",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "site": "nosh-desk",
      "public": "cashier",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    },
    {
      "site": "nosh-carte",
      "public": "menu",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    }
  ],
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
